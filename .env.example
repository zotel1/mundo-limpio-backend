# ============================================================
# MundoLimpio — Variables de Entorno (.env.example)
# ============================================================
# Copiar este archivo a .env y ajustar los valores según el entorno.
#   cp .env.example .env
#
# Este archivo cubre DOS entornos:
#   A) Desarrollo local con Docker Compose (postgres:16-alpine)
#   B) Producción en Render con Supabase PostgreSQL 16
#
# Las variables marcadas con [LOCAL] solo aplican a Docker Compose.
# Las marcadas con [PROD]  solo aplican a Render / application-prod.yml.
# Las marcadas con [SHARED] aplican a ambos entornos.
# ============================================================

# --- [LOCAL] Docker Compose — Base de Datos PostgreSQL local ---
# NOMBRE de la base de datos. Docker Compose crea la DB con este nombre
# en el contenedor postgres:16-alpine.
DB_NAME=mundolimpio

# USUARIO de PostgreSQL para desarrollo local.
# En producción (Supabase), usar PGUSER en su lugar.
DB_USER=postgres

# CONTRASEÑA del usuario PostgreSQL local.
# En producción (Supabase), usar PGPASSWORD en su lugar.
DB_PASSWORD=postgres

# PUERTO del contenedor PostgreSQL mapeado al host.
# Docker Compose mapea este puerto del host al 5432 del contenedor.
DB_PORT=5432

# --- [PROD] Render / Supabase — Conexión PostgreSQL ---
# Estos valores se obtienen del dashboard de Supabase:
#   Supabase > Settings > Database > Connection string
# El connection string tiene el formato:
#   postgresql://postgres.[ref]:[password]@[host]:[port]/[dbname]
# Extraer cada parte y asignarla a la variable correspondiente.

# HOST de Supabase PostgreSQL (ej: aws-0-us-east-1.pooler.supabase.com)
# WHAT: Dirección del servidor PostgreSQL gestionado por Supabase
# WHY: Usar el Pooler (port 6543) para conexiones con pooling integrado
PGHOST=aws-0-us-east-1.pooler.supabase.com

# PUERTO de Supabase PostgreSQL
# 5432 = conexión directa (sin pooling, cuenta contra el límite de 15)
# 6543 = PgBouncer pooler (recomendado para conexiones desde Render)
PGPORT=6543

# NOMBRE de la base de datos en Supabase (por defecto: postgres)
PGDATABASE=postgres

# USUARIO de Supabase PostgreSQL
# Formato típico: postgres.[referencia-del-proyecto]
PGUSER=postgres

# CONTRASEÑA de Supabase PostgreSQL
# Se configura en Supabase > Settings > Database > Database password
PGPASSWORD=tu-contraseña-supabase

# --- [SHARED] Seguridad JWT ---
# CLAVE secreta para firmar y verificar tokens JWT.
# WHAT: Clave HMAC-SHA256 usada por io.jsonwebtoken para firmar JWTs
# WHY: Esta clave DEBE ser aleatoria y secreta. Si se filtra, cualquiera
#      puede generar tokens válidos. Usar al menos 256 bits (32 caracteres).
# CÓMO generar (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 255 }))
# CÓMO generar (Linux/Mac):
#   openssl rand -base64 32
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# --- [SHARED] CORS — Orígenes permitidos para CORS ---
# WHAT: Lista de orígenes separados por coma que pueden acceder a la API
# WHY: La app Flutter (Android/iOS) y el frontend web hacen requests
#      cross-origin. Sin CORS, el browser/emulador bloquea las requests.
#      En producción, agregar la URL de Render del frontend.
# FORMATO: "origen1, origen2, origen3" (separados por coma)
APPLICATION_CORS_ALLOWED_ORIGINS=http://localhost:8080, http://10.0.2.2:8080
